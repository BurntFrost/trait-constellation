{
  "permissions": {
    "allow": [
      "mcp__Claude_Preview__preview_start",
      "mcp__plugin_playwright_playwright__browser_evaluate",
      "mcp__plugin_playwright_playwright__browser_snapshot"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write \"$TOOL_INPUT_file_path\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT_file_path\" | grep -qE '(\\.env|vite\\.config)' && echo 'BLOCK: Modifying deployment-critical config — confirm with user first' && exit 1 || exit 0"
          }
        ]
      }
    ]
  }
}
